import { CalcResult , getTierColor, getTierBgColor } from '../../engine/CalcEngine';
import { calculateCurb65 } from '../../engine/CommonCalculators';
import { AppColors } from '../../utils/AppColors';
import { AppDimens } from '../../utils/AppDimens';

@Component
export struct Curb65Calculator {
  @State resetKey: number = 0;  @State confusion: number = -1;
  @State urea: number = 0;
  @State ureaUnit: string = 'mmol';
  @State rr: number = 0;
  @State sbp: number = 0;
  @State dbp: number = 0;
  @State age: number = 0;
  @State result: CalcResult | null = null;

  aboutToAppear() { this.calculate(); }
  calculate() {
    if (this.confusion < 0) {
      this.result = { value: null, unit: '', tier: 'иѓЈе°ЂеЖЩењЕе°Ђй°є', tierClass: 'tier-info', footnote: '' };
      return;
    }
    this.result = calculateCurb65(this.confusion === 1, this.urea, this.ureaUnit, this.rr, this.sbp, this.dbp, this.age);
  }

  reset() {
    this.confusion = -1;
    this.urea = 0;
    this.ureaUnit = 'mmol';
    this.rr = 0;
    this.sbp = 0;
    this.dbp = 0;
    this.age = 0;
    this.result = null;
    this.resetKey = this.resetKey + 1;
    this.calculate();
  }

  build() {
    if (this.resetKey % 2 === 0) {
      this.CalcContent();
    } else {
      this.CalcContent();
    }
  }

  @Builder
  CalcContent() {
    Column() {
      Column() { Text('зФ®дЇОиѓДдЉ∞з§ЊеМЇиОЈеЊЧжАІиВЇзВОдЄ•йЗНз®ЛеЇ¶еПКдљПйЩҐеЖ≥з≠Ц').fontSize(14).fontColor(AppColors.primary).fontWeight(FontWeight.Medium); Text('5й°єпЉЪжДПиѓЖ+BUN+еСЉеРЄ+и°АеОЛ+еєійЊДвЙ•65пЉМ0-5еИЖ').fontSize(12).fontColor(AppColors.textSecondary).margin({ top: 2 }); }.alignItems(HorizontalAlign.Start).width('100%').margin({ bottom: 12 });

      Column() {
        Row() { Text('вАФ иЊУеЕ•еПВжХ∞').fontSize(12).fontColor(AppColors.warning).fontWeight(FontWeight.Bold).letterSpacing(1.5); Blank(); Text('йЗНзљЃ').fontSize(12).fontColor(AppColors.textSecondary).onClick(() => { this.reset(); }); }.width('100%').margin({ bottom: 12 });
        
        Row() {
          Text('C жДПиѓЖжЈЈдє±').fontSize(14).fontWeight(FontWeight.Medium).fontColor(AppColors.textPrimary).layoutWeight(1);
          Row() {
            Button('еР¶').fontSize(14).fontWeight(FontWeight.Bold).fontColor(this.confusion === 0 ? AppColors.card : AppColors.textOption)
              .backgroundColor(this.confusion === 0 ? AppColors.primary : AppColors.fillNeutral).borderRadius(8).border({ width: 1, color: this.confusion === 0 ? AppColors.primary : AppColors.border }).layoutWeight(1)
              .onClick(() => { this.confusion = 0; this.calculate(); });
            Button('жШѓ').fontSize(14).fontWeight(FontWeight.Bold).fontColor(this.confusion === 1 ? AppColors.card : AppColors.textOption)
              .backgroundColor(this.confusion === 1 ? AppColors.primary : AppColors.fillNeutral).borderRadius(8).border({ width: 1, color: this.confusion === 1 ? AppColors.primary : AppColors.border }).layoutWeight(1)
              .onClick(() => { this.confusion = 1; this.calculate(); });
          }.width(100);
        }.width('100%').margin({ bottom: 8 });

        Row() {
          Column() {
            Text('е∞њзі†ж∞Ѓ').fontSize(14).fontWeight(FontWeight.Medium).fontColor(AppColors.textPrimary).margin({ bottom: 6 });
            TextInput({ placeholder: 'Urea' }).type(InputType.Number).height(AppDimens.inputHeight).fontSize(16).backgroundColor(AppColors.card).borderRadius(8).border({ width: 1, color: AppColors.border }).padding({ left: 12, right: 12 }).placeholderColor(AppColors.placeholder)
              .onChange((value: string) => { this.urea = parseFloat(value) || 0; this.calculate(); });
          }.layoutWeight(1);
          Column() {
            Text('еСЉеРЄйҐСзОЗ').fontSize(14).fontWeight(FontWeight.Medium).fontColor(AppColors.textPrimary).margin({ bottom: 6 });
            TextInput({ placeholder: 'RR' }).type(InputType.Number).height(AppDimens.inputHeight).fontSize(16).backgroundColor(AppColors.card).borderRadius(8).border({ width: 1, color: AppColors.border }).padding({ left: 12, right: 12 }).placeholderColor(AppColors.placeholder)
              .onChange((value: string) => { this.rr = parseFloat(value) || 0; this.calculate(); });
          }.layoutWeight(1).margin({ left: 8 });
        }.width('100%').margin({ bottom: 8 });

        Row() {
          Column() {
            Text('жФґзЉ©еОЛ SBP').fontSize(14).fontWeight(FontWeight.Medium).fontColor(AppColors.textPrimary).margin({ bottom: 6 });
            TextInput({ placeholder: 'SBP' }).type(InputType.Number).height(AppDimens.inputHeight).fontSize(16).backgroundColor(AppColors.card).borderRadius(8).border({ width: 1, color: AppColors.border }).padding({ left: 12, right: 12 }).placeholderColor(AppColors.placeholder)
              .onChange((value: string) => { this.sbp = parseFloat(value) || 0; this.calculate(); });
          }.layoutWeight(1);
          Column() {
            Text('иИТеЉ†еОЛ DBP').fontSize(14).fontWeight(FontWeight.Medium).fontColor(AppColors.textPrimary).margin({ bottom: 6 });
            TextInput({ placeholder: 'DBP' }).type(InputType.Number).height(AppDimens.inputHeight).fontSize(16).backgroundColor(AppColors.card).borderRadius(8).border({ width: 1, color: AppColors.border }).padding({ left: 12, right: 12 }).placeholderColor(AppColors.placeholder)
              .onChange((value: string) => { this.dbp = parseFloat(value) || 0; this.calculate(); });
          }.layoutWeight(1).margin({ left: 8 });
        }.width('100%').margin({ bottom: 8 });

        Column() {
          Text('еєійЊД').fontSize(14).fontWeight(FontWeight.Medium).fontColor(AppColors.textPrimary).margin({ bottom: 6 });
          TextInput({ placeholder: 'еєійЊД' }).type(InputType.Number).height(AppDimens.inputHeight).fontSize(16).backgroundColor(AppColors.card).borderRadius(8).border({ width: 1, color: AppColors.border }).padding({ left: 12, right: 12 }).placeholderColor(AppColors.placeholder)
            .onChange((value: string) => { this.age = parseFloat(value) || 0; this.calculate(); });
        }.width('100%');
      }.padding(AppDimens.cardPadding).backgroundColor(AppColors.card).borderRadius(AppDimens.cardRadius).width('100%').margin({ bottom: 16 });

      if (this.result) {
        Column() {
          Row() {
            Column() {
              Text('CURB-65 Total').fontSize(12).fontColor(AppColors.textSecondary).letterSpacing(1.5);
              Text(this.result!.value !== null ? `${this.result!.value!.toFixed(0)}` : 'вАФ').fontSize(32).fontWeight(FontWeight.Bold).fontColor(AppColors.primary).margin({ top: 4 });
              Text(this.result!.tier).fontSize(13).fontWeight(FontWeight.Bold)
                .fontColor(getTierColor(this.result!.tierClass))
                .backgroundColor(getTierBgColor(this.result!.tierClass))
                .borderRadius(20).padding({ left: 12, right: 12, top: 4, bottom: 4 }).margin({ top: 4 });
            }.alignItems(HorizontalAlign.Start).layoutWeight(1);
            Column() {
              Text(this.result!.footnote).fontSize(14).fontColor(AppColors.textBody).lineHeight(22);
            }.layoutWeight(1).alignItems(HorizontalAlign.Start);
          }.width('100%');
        }.padding(AppDimens.cardPadding).backgroundColor(AppColors.card).borderRadius(AppDimens.cardRadius).width('100%');
      }
    }.width('100%').constraintSize({ minHeight: '100%' }).padding(AppDimens.cardPadding).justifyContent(FlexAlign.Start).alignItems(HorizontalAlign.Start);
  }
}
