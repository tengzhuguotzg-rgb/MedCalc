export class DiagnosisCriterion {
  field: string = '';
  operator: string = '';
  value: string = '';
}

export class DiagnosisRule {
  id: string = '';
  name: string = '';
  category: string = '';
  urgency: string = '';
  ruleType: string = 'diagnosis';
  criteria: DiagnosisCriterion[] = [];
  description: string = '';
  references: string = '';
}

export const DIAGNOSIS_CATEGORIES: string[] = [
  '感染', '呼吸', '肾脏', '心血管', '神经', '血液', '肝', '代谢', '营养'
];

function mc(field: string, operator: string, value: string): DiagnosisCriterion {
  const c = new DiagnosisCriterion();
  c.field = field;
  c.operator = operator;
  c.value = value;
  return c;
}

function mr(id: string, name: string, category: string, urgency: string,
  criteria: DiagnosisCriterion[], description: string, references: string): DiagnosisRule {
  const r = new DiagnosisRule();
  r.id = id;
  r.name = name;
  r.category = category;
  r.urgency = urgency;
  r.ruleType = 'diagnosis';
  r.criteria = criteria;
  r.description = description;
  r.references = references;
  return r;
}

function ma(id: string, name: string, category: string, urgency: string,
  criteria: DiagnosisCriterion[], description: string, references: string): DiagnosisRule {
  const r = new DiagnosisRule();
  r.id = id;
  r.name = name;
  r.category = category;
  r.urgency = urgency;
  r.ruleType = 'alert';
  r.criteria = criteria;
  r.description = description;
  r.references = references;
  return r;
}

